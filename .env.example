# Copy these into Vercel → Project Settings → Environment Variables
# Do NOT commit real values — this file is just a template.

# One random secret used to sign session cookies (do not share / change rarely)
COOKIE_SECRET=your-random-64-char-hex-here

# Comma-separated list of username:password pairs.
# To add more users just append: ,newuser:newpassword
# No redeployment needed after saving in Vercel.
CREDENTIALS=bstr:your-password-here,alice:another-password
